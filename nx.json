{
    "$schema": "./node_modules/nx/schemas/nx-schema.json",
    "npmScope": "poms",
    "affected": {
        "defaultBase": "main"
    },
    "workspaceLayout": {
        "appsDir": "apps",
        "libsDir": "libs"
    },
    "targetDefaults": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "production",
                "^production"
            ],
            "cache": true
        },
        "test": {
            "inputs": [
                "default",
                "^production"
            ],
            "cache": true
        },
        "lint": {
            "inputs": [
                "default",
                "^default"
            ]
        },
        "@nx/js:tsc": {
            "cache": true,
            "dependsOn": [
                "^build"
            ],
            "inputs": [
                "production",
                "^production"
            ]
        }
    },
    "namedInputs": {
        "sharedGlobals": [],
        "default": [
            "{projectRoot}/**/*",
            "sharedGlobals"
        ],
        "production": [
            "default",
            "!{projectRoot}/tsconfig.spec.json",
            "!{projectRoot}/**/*.spec.[jt]s",
            "!{projectRoot}/.eslintrc.json",
            "!{projectRoot}/eslint.config.cjs",
            "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
            "!{projectRoot}/jest.config.[jt]s",
            "!{projectRoot}/src/test-setup.[jt]s",
            "!{projectRoot}/test-setup.[jt]s"
        ]
    },
    "projects": {
        "poms-admin": {
            "tags": []
        }
    },
    "nxCloudId": "69bf9fc63191a96e86a665d5",
    "plugins": [
        {
            "plugin": "@nx/webpack/plugin",
            "options": {
                "buildTargetName": "build",
                "serveTargetName": "serve",
                "previewTargetName": "preview",
                "buildDepsTargetName": "build-deps",
                "watchDepsTargetName": "watch-deps",
                "serveStaticTargetName": "serve-static"
            }
        },
        {
            "plugin": "@nx/eslint/plugin",
            "options": {
                "targetName": "eslint:lint"
            }
        },
        {
            "plugin": "@nx/jest/plugin",
            "options": {
                "targetName": "test"
            },
            "exclude": [
                "poms-api-e2e/**/*",
                "apps-e2e/**/*",
                "apps/poms-api-e2e/**/*"
            ]
        }
    ],
    "generators": {
        "@nx/angular:library": {
            "linter": "eslint",
            "unitTestRunner": "none"
        },
        "@nx/angular:component": {
            "style": "css"
        }
    }
}