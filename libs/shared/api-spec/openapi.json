          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "subtitle": {
            "type": "string",
            "nullable": true
          },
          "link": {
            "type": "string",
            "nullable": true
          },
          "icon": {
            "type": "string",
            "nullable": true
          },
          "displayOrder": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "isHidden": {
            "type": "boolean"
          },
          "isDisabled": {
            "type": "boolean"
          },
          "requiredPermissions": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "platform:users:manage",
                "platform:roles:manage",
                "platform:navigation:manage",
                "platform:org-units:manage",
                "project:read",
                "project:write",
                "project:delete",
                "nav:dashboard:view",
                "nav:platform:view",
                "nav:projects:view",
                "nav:profile:view"
              ]
            },
            "nullable": true
          },
          "meta": {
            "type": "object",
            "properties": {},
            "additionalProperties": {},
            "nullable": true
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NavigationListDto__schema0"
            },
            "nullable": true
          }
        },
        "required": [
          "id",
          "key",
          "type",
          "title",
          "subtitle",
          "link",
          "icon",
          "displayOrder",
          "isHidden",
          "isDisabled",
          "requiredPermissions",
          "meta",
          "children"
        ],
        "id": "NavigationItem"
      },
      "NavigationListDto": {
        "type": "array",
        "items": {
          "$ref": "#/components/schemas/NavigationListDto__schema0"
        },
        "id": "NavigationList"
      },
